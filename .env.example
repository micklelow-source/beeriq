# Copy to .env and adjust. Never commit real secrets.

# --- Backend ---
BREWIQ_ENV=development
BREWIQ_LOG_LEVEL=INFO
BREWIQ_LOG_JSON=false

# Async SQLAlchemy URL. Docker Compose overrides this to point at the db service.
BREWIQ_DATABASE_URL=postgresql+asyncpg://brewiq:brewiq@localhost:5432/brewiq

# Redis (Celery broker / cache), used by later phases.
BREWIQ_REDIS_URL=redis://localhost:6379/0

# Comma-separated frontend origin(s) allowed to call the API when
# BREWIQ_ENV=production (e.g. https://brewiq-frontend.onrender.com). Ignored
# outside production.
BREWIQ_CORS_ALLOW_ORIGINS=

# Discovery / scraper tuning
BREWIQ_HTTP_TIMEOUT_SECONDS=15
BREWIQ_HTTP_USER_AGENT=BrewIQBot/0.1 (+https://github.com/micklelow-source/beeriq)
BREWIQ_DISCOVERY_MAX_CONCURRENCY=5

# --- AI providers (Phase 6 §3, not yet wired) ---
# BREWIQ_AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Optional: enables Google Places autocomplete on the address bar. Without it, the
# address bar still opens Google Maps for "breweries near <address>".
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
